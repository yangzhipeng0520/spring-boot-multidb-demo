<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.multidb.mapper.AppConfigMapper">

    <select id="selectByConfigKey" resultType="com.example.multidb.entity.AppConfig">
        select
            id,
            config_key,
            config_value,
            remark,
            create_time,
            update_time
        from app_config
        where config_key = #{configKey}
    </select>

</mapper>

